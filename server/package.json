{
  "name": "fetchr-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').mkdirSync('dist/db/migrations',{recursive:true}); require('fs').readdirSync('src/db/migrations').forEach(f=>require('fs').copyFileSync('src/db/migrations/'+f,'dist/db/migrations/'+f));\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.3.0",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.9.1",
    "@types/node-fetch": "^2.6.11",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "supertest": "^7.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.7"
  }
}
